<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:yummy="clr-namespace:Xamarin.Forms.PancakeView;assembly=Xamarin.Forms.PancakeView"
             x:Class="KADJFAPI.Views.Payment"
             BackgroundColor="Transparent"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="PrimaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#0D4D2A" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="13" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style x:Key="SecondaryButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="Transparent" />
                <Setter Property="TextColor" Value="#0D4D2A" />
                <Setter Property="BorderWidth" Value="1.5" />
                <Setter Property="BorderColor" Value="#0D4D2A" />
                <Setter Property="CornerRadius" Value="13" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,4" />
            </Style>

            <Style x:Key="ReprintButtonStyle" TargetType="Button">
                <Setter Property="BackgroundColor" Value="#E67E22" />
                <Setter Property="TextColor" Value="White" />
                <Setter Property="CornerRadius" Value="13" />
                <Setter Property="HeightRequest" Value="52" />
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="Margin" Value="0,4" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#66031109" Offset="0.0" />
                <GradientStop Color="#99031109" Offset="0.5" />
                <GradientStop Color="#C4020806" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnBackgroundTapped" />
        </Grid.GestureRecognizers>

        <!-- Loading -->
        <StackLayout x:Name="LoadingContainer"
                     IsVisible="False"
                     VerticalOptions="Center" HorizontalOptions="Center"
                     BackgroundColor="#CC031109"
                     Padding="32,24" Spacing="15">
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsVisible="False" IsRunning="False"
                               Color="#1F8C4F" Scale="1.8" />
            <Label Text="Processing Payment..."
                   TextColor="White" FontSize="16" FontAttributes="Bold"
                   HorizontalOptions="Center" />
        </StackLayout>

        <!-- Sheet (KEEP AS Frame — code manipulates SheetFrame) -->
        <Frame x:Name="SheetFrame"
               VerticalOptions="End"
               HorizontalOptions="FillAndExpand"
               BackgroundColor="White"
               CornerRadius="22"
               HasShadow="True"
               Padding="0"
               Margin="8,0,8,8"
               TranslationY="250">

            <Frame.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnSheetTapped" />
            </Frame.GestureRecognizers>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Drag handle -->
                <StackLayout x:Name="DragHandleArea"
                             Grid.Row="0"
                             Padding="0,12,0,8"
                             BackgroundColor="Transparent"
                             HeightRequest="44">
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnSheetTapped" />
                    </StackLayout.GestureRecognizers>
                    <BoxView x:Name="DragHandle"
                             HeightRequest="5"
                             WidthRequest="48"
                             BackgroundColor="#D9E3DC"
                             HorizontalOptions="Center"
                             VerticalOptions="Start"
                             CornerRadius="3" />
                </StackLayout>

                <!-- Content -->
                <ScrollView Grid.Row="1"
                            Padding="24,4,24,32"
                            VerticalScrollBarVisibility="Never">
                    <StackLayout Spacing="12" Orientation="Vertical">

                        <!-- Header -->
                        <StackLayout Spacing="10" Margin="0,0,0,8">
                            <StackLayout.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnSheetTapped" />
                            </StackLayout.GestureRecognizers>

                            <yummy:PancakeView CornerRadius="32"
                                               WidthRequest="68" HeightRequest="68"
                                               HorizontalOptions="Center"
                                               Elevation="4"
                                               BorderThickness="1.5"
                                               BorderGradientStartColor="#E6CC7A"
                                               BorderGradientEndColor="#9A7D33"
                                               BorderGradientAngle="135"
                                               Padding="0" Margin="0,0,0,2">
                                <yummy:PancakeView.BackgroundGradientStops>
                                    <yummy:GradientStopCollection>
                                        <yummy:GradientStop Color="#0D4D2A" Offset="0.0"/>
                                        <yummy:GradientStop Color="#030F0A" Offset="1.0"/>
                                    </yummy:GradientStopCollection>
                                </yummy:PancakeView.BackgroundGradientStops>
                                <Image Source="Logo" Aspect="AspectFit"
                                       Margin="14"
                                       HorizontalOptions="Center" VerticalOptions="Center"/>
                            </yummy:PancakeView>

                            <Label Text="KADUNA JUDICIARY PAYMENT"
                                   FontSize="20" FontAttributes="Bold"
                                   HorizontalOptions="Center" TextColor="#14241B" />

                            <Label Text="SECURE PAYMENT PROCESSING"
                                   FontSize="12" FontAttributes="Bold"
                                   CharacterSpacing="1"
                                   HorizontalOptions="Center"
                                   TextColor="#1A7A45" Margin="0,-4,0,0" />
                        </StackLayout>

                        <!-- Invoice number -->
                        <StackLayout Spacing="8">
                            <Label Text="INVOICE NUMBER"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1" TextColor="#4D7A61"
                                   Margin="2,0,0,0"/>
                            <Frame x:Name="TokenInputFrame"
                                   HasShadow="False"
                                   BorderColor="#DDE7E0"
                                   CornerRadius="13"
                                   Padding="14,0"
                                   BackgroundColor="#F6FAF7"
                                   HeightRequest="54">
                                <Entry x:Name="inputtoken"
                                       Placeholder="Enter your Invoice Number"
                                       HorizontalOptions="FillAndExpand"
                                       HeightRequest="54"
                                       BackgroundColor="Transparent"
                                       FontSize="15"
                                       TextColor="#14241B"
                                       TextChanged="OnTokenTextChanged"
                                       Completed="OnTokenCompleted"
                                       MaxLength="30"
                                       ClearButtonVisibility="WhileEditing"
                                       PlaceholderColor="#9CB3A4" />
                            </Frame>
                            <Label x:Name="TokenHintLabel"
                                   Text="Format: numeric (6–20 digits)"
                                   FontSize="11" TextColor="#9CB3A4"
                                   IsVisible="True" Margin="2,0,0,0" />
                        </StackLayout>

                        <!-- Payment method -->
                        <StackLayout Spacing="8">
                            <Label Text="PAYMENT METHOD"
                                   FontSize="11" FontAttributes="Bold"
                                   CharacterSpacing="1" TextColor="#4D7A61"
                                   Margin="2,0,0,0"/>
                            <Frame HasShadow="False"
                                   BorderColor="#DDE7E0"
                                   CornerRadius="13"
                                   Padding="14,2"
                                   BackgroundColor="#F6FAF7"
                                   HeightRequest="54">
                                <Picker Title="Select Payment Method"
                                        FontSize="15"
                                        x:Name="paymentmethod"
                                        BackgroundColor="Transparent"
                                        HeightRequest="54"
                                        TitleColor="#9CB3A4"
                                        TextColor="#14241B"
                                        HorizontalOptions="FillAndExpand"
                                        SelectedIndexChanged="OnPaymentMethodChanged">
                                    <Picker.ItemsSource>
                                        <x:Array Type="{x:Type x:String}">
                                            <x:String>Cash</x:String>
                                            <x:String>Others Method</x:String>
                                        </x:Array>
                                    </Picker.ItemsSource>
                                </Picker>
                            </Frame>
                        </StackLayout>

                        <!-- Message (code sets MessageFrame.BackgroundColor) -->
                        <StackLayout x:Name="MessageContainer" IsVisible="False">
                            <Frame x:Name="MessageFrame"
                                   CornerRadius="12" HasShadow="False"
                                   Padding="14" Margin="0,4"
                                   BorderColor="Transparent">
                                <StackLayout Orientation="Horizontal" Spacing="10">
                                    <Label x:Name="MessageIcon" FontSize="17" VerticalOptions="Center" />
                                    <Label x:Name="MessageLabel" FontSize="13.5"
                                           VerticalOptions="Center"
                                           HorizontalOptions="FillAndExpand"
                                           LineBreakMode="WordWrap" />
                                </StackLayout>
                            </Frame>
                        </StackLayout>

                        <!-- Actions -->
                        <StackLayout Spacing="4" Margin="0,12,0,0">
                            <Button x:Name="VerifyButton"
                                    CornerRadius="13" HeightRequest="52"
                                    Text="Process Payment"
                                    Clicked="OnVerifyTokenClicked"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    IsEnabled="False"/>

                            <Button x:Name="ReprintButton"
                                    Text="🖨️  Reprint Receipt"
                                    CornerRadius="13" HeightRequest="52"
                                    Style="{StaticResource ReprintButtonStyle}"
                                    IsVisible="False"
                                    Clicked="OnReprintReceiptClicked"/>

                            <Button x:Name="CancelButton"
                                    Text="Cancel"
                                    CornerRadius="13"
                                    Clicked="OnCancelClicked"
                                    Style="{StaticResource SecondaryButtonStyle}"/>
                        </StackLayout>

                        <!-- Generate link -->
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center"
                                     Spacing="6" Margin="0,12,0,4">
                            <Label Text="Don't have an Invoice?" FontSize="13.5" TextColor="#5E7A68" />
                            <Label Text="Generate Invoice"
                                   FontSize="13.5" TextColor="#1A7A45"
                                   FontAttributes="Bold" TextDecorations="Underline">
                                <Label.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnResendTokenTapped" />
                                </Label.GestureRecognizers>
                            </Label>
                        </StackLayout>

                        <!-- Security -->
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center"
                                     Spacing="5" Margin="0,8,0,8">
                            <Label Text="🔒" FontSize="12" />
                            <Label Text="Your payment is secured with SSL encryption"
                                   FontSize="11.5" TextColor="#9CB3A4"
                                   HorizontalOptions="Center" />
                        </StackLayout>

                    </StackLayout>
                </ScrollView>
            </Grid>
        </Frame>
    </Grid>
</ContentPage>
