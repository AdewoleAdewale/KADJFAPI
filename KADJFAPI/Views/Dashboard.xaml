<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:yummy="clr-namespace:Xamarin.Forms.PancakeView;assembly=Xamarin.Forms.PancakeView"
             x:Class="KADJFAPI.Views.Dashboard"
             BackgroundColor="#F4F7F5"
             NavigationPage.HasNavigationBar="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!-- Refined Emerald / Gold Palette -->
            <Color x:Key="PrimaryColor">#0D4D2A</Color>
            <Color x:Key="PrimaryDark">#030F0A</Color>
            <Color x:Key="PrimaryMid">#1A7A45</Color>
            <Color x:Key="SecondaryColor">#1F8C4F</Color>
            <Color x:Key="Gold">#C8A84B</Color>
            <Color x:Key="GoldLight">#E6CC7A</Color>

            <Color x:Key="DangerColor">#EF4444</Color>
            <Color x:Key="SuccessColor">#22C55E</Color>
            <Color x:Key="WarningColor">#F59E0B</Color>
            <Color x:Key="AccentColor">#F59E0B</Color>
            <Color x:Key="InfoColor">#06B6D4</Color>

            <Color x:Key="CardBackground">#FFFFFF</Color>
            <Color x:Key="BackgroundPrimary">#F4F7F5</Color>
            <Color x:Key="BackgroundSecondary">#EAF1EC</Color>

            <Color x:Key="TextPrimary">#14241B</Color>
            <Color x:Key="TextSecondary">#5E7A68</Color>
            <Color x:Key="TextMuted">#9CA3AF</Color>
            <Color x:Key="TextWhite">#FFFFFF</Color>

            <!-- Cards -->
            <Style x:Key="ModernCard" TargetType="yummy:PancakeView">
                <Setter Property="BackgroundGradientStartColor" Value="Green" />
                <Setter Property="BackgroundGradientEndColor" Value="ForestGreen" />
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Elevation" Value="6" />
                <Setter Property="BorderColor" Value="#E7EDE9" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="14" />
                <Setter Property="Margin" Value="6" />
            </Style>

            <!-- Primary gradient button -->
            <Style x:Key="PrimaryGradientButton" TargetType="yummy:PancakeView">
                <Setter Property="BackgroundGradientStartColor" Value="{StaticResource PrimaryMid}" />
                <Setter Property="BackgroundGradientEndColor" Value="{StaticResource PrimaryColor}" />
                <Setter Property="BackgroundGradientAngle" Value="135" />
                <Setter Property="CornerRadius" Value="12" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Elevation" Value="4" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="Padding" Value="18,0" />
            </Style>

            <!-- Typography -->
            <Style x:Key="HeroTitle" TargetType="Label">
                <Setter Property="FontSize" Value="28" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
                <Setter Property="LineHeight" Value="1.1" />
            </Style>

            <Style x:Key="SectionTitle" TargetType="Label">
                <Setter Property="FontSize" Value="20" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <Style x:Key="CardTitle" TargetType="Label">
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
            </Style>

            <Style x:Key="CardSubtitle" TargetType="Label">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
                <Setter Property="Margin" Value="0,3,0,0" />
            </Style>

            <Style x:Key="ButtonText" TargetType="Label">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource TextWhite}" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Center" />
            </Style>

            <!-- Icon tile -->
            <Style x:Key="IconContainer" TargetType="yummy:PancakeView">
                <Setter Property="CornerRadius" Value="16" />
                <Setter Property="WidthRequest" Value="56" />
                <Setter Property="HeightRequest" Value="56" />
                <Setter Property="HasShadow" Value="True" />
                <Setter Property="Elevation" Value="3" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid>
        <ScrollView x:Name="MainScrollView" HorizontalOptions="FillAndExpand" VerticalOptions="FillAndExpand">
            <StackLayout Spacing="0" Padding="0">

                <!-- ══ HEADER ══════════════════════════════════════ -->
                <yummy:PancakeView x:Name="HeaderSection"
                                   CornerRadius="0,0,32,32"
                                   BackgroundGradientAngle="160"
                                   Padding="22,52,22,30"
                                   HasShadow="True"
                                   Elevation="12">
                    <yummy:PancakeView.BackgroundGradientStops>
                        <yummy:GradientStopCollection>
                            <yummy:GradientStop Color="#11623A" Offset="0.0"/>
                            <yummy:GradientStop Color="#0A3D22" Offset="0.55"/>
                            <yummy:GradientStop Color="#041710" Offset="1.0"/>
                        </yummy:GradientStopCollection>
                    </yummy:PancakeView.BackgroundGradientStops>

                    <StackLayout Spacing="0">

                        <!-- Top navigation -->
                        <Grid x:Name="TopNavigation" Margin="0,0,0,22">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <yummy:PancakeView Grid.Column="0"
                                               BackgroundColor="#1FFFFFFF"
                                               BorderColor="#33FFFFFF"
                                               BorderThickness="1"
                                               CornerRadius="13"
                                               WidthRequest="44"
                                               HeightRequest="44">
                                <Image Source="hamburgerMenu"
                                       HeightRequest="18" WidthRequest="18"
                                       VerticalOptions="Center" HorizontalOptions="Center"
                                       Aspect="AspectFit" />
                            </yummy:PancakeView>

                            <StackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         VerticalOptions="Center"
                                         Spacing="2">
                                <Label Text="KADUNA STATE"
                                       TextColor="{StaticResource GoldLight}"
                                       FontSize="16" FontAttributes="Bold"
                                       CharacterSpacing="2"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="JUDICIARY"
                                       TextColor="#9FBFAC"
                                       FontSize="11" FontAttributes="Bold"
                                       CharacterSpacing="3"
                                       HorizontalTextAlignment="Center" />
                            </StackLayout>

                            <yummy:PancakeView Grid.Column="2"
                                               BackgroundColor="#1FFFFFFF"
                                               BorderColor="#33FFFFFF"
                                               BorderThickness="1"
                                               CornerRadius="13"
                                               WidthRequest="44"
                                               HeightRequest="44">
                                <Image Source="shutdown"
                                       HeightRequest="18" WidthRequest="18"
                                       VerticalOptions="Center" HorizontalOptions="Center"
                                       Aspect="AspectFit">
                                    <Image.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnLogoutClicked" />
                                    </Image.GestureRecognizers>
                                </Image>
                            </yummy:PancakeView>
                        </Grid>

                        <!-- Welcome + crest -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackLayout Grid.Column="0"
                                         x:Name="WelcomeSection"
                                         VerticalOptions="Center"
                                         Spacing="8">
                                <Label Text="Welcome back,"
                                       FontSize="15"
                                       TextColor="#9FBFAC"
                                       x:Name="WelcomeLabel" />
                                <Label x:Name="UserNameLabel"
                                       Style="{StaticResource HeroTitle}"
                                       TextTransform="Uppercase" />

                                <!-- Department badge -->
                                <yummy:PancakeView x:Name="DepartmentBadge"
                                                   BackgroundColor="#22FFFFFF"
                                                   BorderColor="#3DC8A84B"
                                                   BorderThickness="1"
                                                   CornerRadius="9"
                                                   Padding="12,6"
                                                   Margin="0,6,0,0"
                                                   HorizontalOptions="Start">
                                    <Label x:Name="MdaLabel"
                                           FontSize="11"
                                           TextColor="{StaticResource GoldLight}"
                                           FontAttributes="Bold"
                                           CharacterSpacing="0.5"
                                           TextTransform="Uppercase" />
                                </yummy:PancakeView>
                            </StackLayout>

                            <!-- Crest -->
                            <yummy:PancakeView Grid.Column="1"
                                               x:Name="ProfileFrame"
                                               WidthRequest="100"
                                               HeightRequest="100"
                                               CornerRadius="24"
                                               Padding="0"
                                               BorderThickness="1.5"
                                               BorderGradientStartColor="#E6CC7A"
                                               BorderGradientEndColor="#9A7D33"
                                               BorderGradientAngle="135"
                                               HasShadow="True"
                                               Elevation="10"
                                               VerticalOptions="Center">
                                <yummy:PancakeView.BackgroundGradientStops>
                                    <yummy:GradientStopCollection>
                                        <yummy:GradientStop Color="#0D4D2A" Offset="0.0"/>
                                        <yummy:GradientStop Color="#030F0A" Offset="1.0"/>
                                    </yummy:GradientStopCollection>
                                </yummy:PancakeView.BackgroundGradientStops>

                                <yummy:PancakeView WidthRequest="78"
                                                   HeightRequest="78"
                                                   CornerRadius="39"
                                                   BorderThickness="1"
                                                   BorderColor="#C8A84B"
                                                   BackgroundColor="#0A3D22"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                    <Image Source="Logo"
                                           Aspect="AspectFit"
                                           Margin="13"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center" />
                                </yummy:PancakeView>
                            </yummy:PancakeView>
                        </Grid>

                        <!-- Stats -->
                        <Grid x:Name="StatsGrid" Margin="0,24,0,0" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <yummy:PancakeView Grid.Column="0"
                                               BackgroundColor="#1AFFFFFF"
                                               BorderColor="#2EFFFFFF"
                                               BorderThickness="1"
                                               CornerRadius="14"
                                               Padding="10,14">
                                <StackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label x:Name="TotalTransactionsLabel"
                                           Text="0" FontSize="22" FontAttributes="Bold"
                                           TextColor="{StaticResource TextWhite}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="TOTAL" FontSize="9"
                                           CharacterSpacing="1"
                                           TextColor="#C8A84B" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                            </yummy:PancakeView>

                            <yummy:PancakeView Grid.Column="1"
                                               BackgroundColor="#1AFFFFFF"
                                               BorderColor="#2EFFFFFF"
                                               BorderThickness="1"
                                               CornerRadius="14"
                                               Padding="10,14">
                                <StackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label x:Name="PendingTransactionsLabel"
                                           Text="0" FontSize="22" FontAttributes="Bold"
                                           TextColor="{StaticResource TextWhite}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="PENDING" FontSize="9"
                                           CharacterSpacing="1"
                                           TextColor="#C8A84B" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                            </yummy:PancakeView>

                            <yummy:PancakeView Grid.Column="2"
                                               BackgroundColor="#1AFFFFFF"
                                               BorderColor="#2EFFFFFF"
                                               BorderThickness="1"
                                               CornerRadius="14"
                                               Padding="10,14">
                                <StackLayout Spacing="4" HorizontalOptions="Center">
                                    <Label x:Name="CompletedTransactionsLabel"
                                           Text="0" FontSize="22" FontAttributes="Bold"
                                           TextColor="{StaticResource TextWhite}"
                                           HorizontalTextAlignment="Center" />
                                    <Label Text="COMPLETED" FontSize="9"
                                           CharacterSpacing="1"
                                           TextColor="#C8A84B" FontAttributes="Bold"
                                           HorizontalTextAlignment="Center" />
                                </StackLayout>
                            </yummy:PancakeView>
                        </Grid>
                    </StackLayout>
                </yummy:PancakeView>

                <!-- ══ QUICK ACTIONS ═══════════════════════════════ -->
                <StackLayout Padding="12,18,12,8"
                             x:Name="QuickActionsSection"
                             BackgroundColor="{StaticResource BackgroundPrimary}"
                             Spacing="12">

                    <StackLayout Orientation="Horizontal" Spacing="10" Margin="4,0,0,0">
                        <yummy:PancakeView BackgroundGradientStartColor="{StaticResource Gold}"
                                           BackgroundGradientEndColor="{StaticResource SecondaryColor}"
                                           BackgroundGradientAngle="135"
                                           WidthRequest="4" HeightRequest="26" CornerRadius="2" />
                        <Label Style="{StaticResource SectionTitle}" Text="Quick Actions" />
                    </StackLayout>

                    <Grid x:Name="QuickActionsGrid" ColumnSpacing="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Generate Invoice -->
                        <yummy:PancakeView Grid.Column="0"
                                           Style="{StaticResource ModernCard}"
                                           HeightRequest="122"
                                           x:Name="GenerateInvoiceCard">
                            
                            <StackLayout Spacing="10" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand">
                                <yummy:PancakeView Style="{StaticResource IconContainer}"
                                                   BackgroundGradientStartColor="{StaticResource PrimaryMid}"
                                                   BackgroundGradientEndColor="{StaticResource PrimaryColor}"
                                                   BackgroundGradientAngle="135"
                                                   HorizontalOptions="Center">
                                    <yummy:PancakeView.BackgroundGradientStops>
                                        <yummy:GradientStopCollection>
                                            <yummy:GradientStop Color="#11623A" Offset="0.0"/>
                                            <yummy:GradientStop Color="#0A3D22" Offset="0.55"/>
                                            <yummy:GradientStop Color="#041710" Offset="1.0"/>
                                        </yummy:GradientStopCollection>
                                    </yummy:PancakeView.BackgroundGradientStops>
                                    <Label Text="🧾" FontSize="26"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </yummy:PancakeView>
                                <Label Text="GENERATE&#10;INVOICE"
                                       FontAttributes="Bold" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="Center" />
                            </StackLayout>
                            <yummy:PancakeView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_5"/>
                            </yummy:PancakeView.GestureRecognizers>
                        </yummy:PancakeView>

                        <!-- Verify Invoice -->
                        <yummy:PancakeView Grid.Column="1"
                                           Style="{StaticResource ModernCard}"
                                           HeightRequest="122"
                                           x:Name="VerifyRRRCard">
                            <StackLayout Spacing="10" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand">
                                <yummy:PancakeView Style="{StaticResource IconContainer}"
                                                   BackgroundGradientStartColor="{StaticResource PrimaryColor}"
                                                   BackgroundGradientEndColor="{StaticResource PrimaryMid}"
                                                   BackgroundGradientAngle="135"
                                                   HorizontalOptions="Center">
                                    <Label Text="🔍" FontSize="26"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </yummy:PancakeView>
                                <Label Text="VERIFY&#10;INVOICE"
                                       FontAttributes="Bold" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="Center" />
                            </StackLayout>
                            <yummy:PancakeView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_3"/>
                            </yummy:PancakeView.GestureRecognizers>
                        </yummy:PancakeView>

                        <!-- Check History -->
                        <yummy:PancakeView Grid.Column="2"
                                           Style="{StaticResource ModernCard}"
                                           HeightRequest="122"
                                           x:Name="CheckHistoryCard">
                            <StackLayout Spacing="10" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand">
                                <yummy:PancakeView Style="{StaticResource IconContainer}"
                                                   BackgroundGradientStartColor="{StaticResource PrimaryMid}"
                                                   BackgroundGradientEndColor="{StaticResource PrimaryColor}"
                                                   BackgroundGradientAngle="135"
                                                   HorizontalOptions="Center">
                                    <Label Text="🕘" FontSize="26"
                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                </yummy:PancakeView>
                                <Label Text="CHECK&#10;HISTORY"
                                       FontAttributes="Bold" FontSize="12"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="Center" />
                            </StackLayout>
                            <yummy:PancakeView.GestureRecognizers>
                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped"/>
                            </yummy:PancakeView.GestureRecognizers>
                        </yummy:PancakeView>
                    </Grid>
                </StackLayout>

                <!-- ══ ADDITIONAL SERVICES ═════════════════════════ -->
                <StackLayout Padding="12,8,12,8"
                             BackgroundColor="{StaticResource BackgroundPrimary}"
                             x:Name="ServicesSection"
                             Spacing="12">

                    <StackLayout Orientation="Horizontal" Spacing="10" Margin="4,0,0,0">
                        <yummy:PancakeView BackgroundGradientStartColor="{StaticResource Gold}"
                                           BackgroundGradientEndColor="{StaticResource SecondaryColor}"
                                           BackgroundGradientAngle="135"
                                           WidthRequest="4" HeightRequest="26" CornerRadius="2" />
                        <Label Style="{StaticResource SectionTitle}" Text="Additional Services" />
                    </StackLayout>

                    <Grid RowSpacing="0" ColumnSpacing="0" x:Name="ServicesGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Courts -->
                        <yummy:PancakeView Grid.Row="0" Grid.Column="0"
                                           Style="{StaticResource ModernCard}"
                                           x:Name="CourtsServiceCard">
                            <StackLayout Spacing="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <yummy:PancakeView Grid.Column="0"
                                                       BackgroundGradientStartColor="{StaticResource PrimaryMid}"
                                                       BackgroundGradientEndColor="{StaticResource PrimaryColor}"
                                                       BackgroundGradientAngle="135"
                                                       CornerRadius="14" WidthRequest="48" HeightRequest="48"
                                                       HasShadow="True" Elevation="3">
                                        <Label Text="🏛️" FontSize="22"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </yummy:PancakeView>
                                    <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <Label Text="Courts" Style="{StaticResource CardTitle}" />
                                        <Label Text="View all courts" Style="{StaticResource CardSubtitle}" />
                                    </StackLayout>
                                </Grid>
                                <yummy:PancakeView Style="{StaticResource PrimaryGradientButton}">
                                    <Label Style="{StaticResource ButtonText}" Text="View Courts" />
                                    <yummy:PancakeView.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="Button_Clicked" />
                                    </yummy:PancakeView.GestureRecognizers>
                                </yummy:PancakeView>
                            </StackLayout>
                        </yummy:PancakeView>

                        <!-- Payment -->
                        <yummy:PancakeView Grid.Row="0" Grid.Column="1"
                                           Style="{StaticResource ModernCard}"
                                           x:Name="PaymentServiceCard">
                            <StackLayout Spacing="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <yummy:PancakeView Grid.Column="0"
                                                       BackgroundGradientStartColor="{StaticResource PrimaryMid}"
                                                       BackgroundGradientEndColor="{StaticResource PrimaryColor}"
                                                       BackgroundGradientAngle="135"
                                                       CornerRadius="14" WidthRequest="48" HeightRequest="48"
                                                       HasShadow="True" Elevation="3">
                                        <Label Text="💳" FontSize="22"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </yummy:PancakeView>
                                    <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <Label Text="Payment" Style="{StaticResource CardTitle}" />
                                        <Label Text="Pay with invoice" Style="{StaticResource CardSubtitle}" />
                                    </StackLayout>
                                </Grid>
                                <yummy:PancakeView Style="{StaticResource PrimaryGradientButton}">
                                    <Label Style="{StaticResource ButtonText}" Text="Pay Now" />
                                    <yummy:PancakeView.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_4" />
                                    </yummy:PancakeView.GestureRecognizers>
                                </yummy:PancakeView>
                            </StackLayout>
                        </yummy:PancakeView>

                        <!-- Test Printer -->
                        <yummy:PancakeView Grid.Row="1" Grid.Column="0"
                                           Style="{StaticResource ModernCard}"
                                           x:Name="PrinterServiceCard">
                            <StackLayout Spacing="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <yummy:PancakeView Grid.Column="0"
                                                       BackgroundGradientStartColor="{StaticResource PrimaryMid}"
                                                       BackgroundGradientEndColor="{StaticResource PrimaryColor}"
                                                       BackgroundGradientAngle="135"
                                                       CornerRadius="14" WidthRequest="48" HeightRequest="48"
                                                       HasShadow="True" Elevation="3">
                                        <Label Text="🖨️" FontSize="22"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </yummy:PancakeView>
                                    <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <Label Text="Test Printer" Style="{StaticResource CardTitle}" />
                                        <Label Text="Check status" Style="{StaticResource CardSubtitle}" />
                                    </StackLayout>
                                </Grid>
                                <yummy:PancakeView Style="{StaticResource PrimaryGradientButton}">
                                    <Label Style="{StaticResource ButtonText}" Text="Test Now" />
                                    <yummy:PancakeView.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_1" />
                                    </yummy:PancakeView.GestureRecognizers>
                                </yummy:PancakeView>
                            </StackLayout>
                        </yummy:PancakeView>

                        <!-- Support -->
                        <yummy:PancakeView Grid.Row="1" Grid.Column="1"
                                           Style="{StaticResource ModernCard}"
                                           x:Name="SupportServiceCard">
                            <StackLayout Spacing="12">
                                <Grid ColumnSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <yummy:PancakeView Grid.Column="0"
                                                       BackgroundGradientStartColor="{StaticResource Gold}"
                                                       BackgroundGradientEndColor="#9A7D33"
                                                       BackgroundGradientAngle="135"
                                                       CornerRadius="14" WidthRequest="48" HeightRequest="48"
                                                       HasShadow="True" Elevation="3">
                                        <Label Text="📞" FontSize="22"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                    </yummy:PancakeView>
                                    <StackLayout Grid.Column="1" VerticalOptions="Center" Spacing="3">
                                        <Label Text="Support" Style="{StaticResource CardTitle}" />
                                        <Label Text="Get assistance" Style="{StaticResource CardSubtitle}" />
                                    </StackLayout>
                                </Grid>
                                <yummy:PancakeView Style="{StaticResource PrimaryGradientButton}"
                                                   BackgroundGradientStartColor="{StaticResource Gold}"
                                                   BackgroundGradientEndColor="#9A7D33">
                                    <Label Style="{StaticResource ButtonText}" Text="Contact Us" />
                                    <yummy:PancakeView.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnSupportClicked" />
                                    </yummy:PancakeView.GestureRecognizers>
                                </yummy:PancakeView>
                            </StackLayout>
                        </yummy:PancakeView>
                    </Grid>
                </StackLayout>

                <!-- ══ RECENT INVOICES ═════════════════════════════ -->
                <yummy:PancakeView BackgroundColor="{StaticResource CardBackground}"
                                   CornerRadius="24,24,0,0"
                                   HasShadow="True"
                                   Elevation="12"
                                   Padding="16,18,16,16"
                                   Margin="0,8,0,0"
                                   x:Name="RecentInvoicesSection">
                    <StackLayout Spacing="18">

                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackLayout Grid.Column="0" Orientation="Horizontal" Spacing="10" VerticalOptions="Center">
                                <yummy:PancakeView BackgroundGradientStartColor="{StaticResource Gold}"
                                                   BackgroundGradientEndColor="{StaticResource SecondaryColor}"
                                                   BackgroundGradientAngle="135"
                                                   WidthRequest="4" HeightRequest="36" CornerRadius="2" />
                                <StackLayout Spacing="2">
                                    <Label Text="Recent Invoices" Style="{StaticResource SectionTitle}" />
                                    <Label Text="Your latest transactions" Style="{StaticResource CardSubtitle}" Margin="0" />
                                </StackLayout>
                            </StackLayout>

                            <yummy:PancakeView Grid.Column="1"
                                               BackgroundColor="#0F2A1B"
                                               BorderColor="#C8A84B"
                                               BorderThickness="1"
                                               CornerRadius="10"
                                               HeightRequest="38"
                                               Padding="16,0"
                                               VerticalOptions="Center">
                                <Label Text="VIEW ALL"
                                       FontAttributes="Bold" FontSize="11"
                                       CharacterSpacing="1"
                                       TextColor="{StaticResource GoldLight}"
                                       VerticalOptions="Center" HorizontalOptions="Center" />
                            </yummy:PancakeView>
                        </Grid>

                        <!-- List -->
                        <ListView x:Name="listView"
                                  BackgroundColor="Transparent"
                                  ItemsSource="{Binding HD}"
                                  HeightRequest="200"
                                  ItemSelected="listView_ItemSelected"
                                  HorizontalOptions="FillAndExpand"
                                  HasUnevenRows="True"
                                  SeparatorVisibility="None"
                                  VerticalOptions="FillAndExpand">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <ViewCell>
                                        <yummy:PancakeView BackgroundColor="#FBFDFC"
                                                           CornerRadius="14"
                                                           HasShadow="True"
                                                           Elevation="3"
                                                           BorderColor="#EAF1EC"
                                                           BorderThickness="1"
                                                           Padding="12"
                                                           Margin="2,6">
                                            <Grid RowSpacing="8" ColumnSpacing="12">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <yummy:PancakeView Grid.Row="0" Grid.RowSpan="3" Grid.Column="0"
                                                                   BackgroundGradientStartColor="#1A7A45"
                                                                   BackgroundGradientEndColor="#0D4D2A"
                                                                   BackgroundGradientAngle="135"
                                                                   CornerRadius="14"
                                                                   WidthRequest="50" HeightRequest="50"
                                                                   VerticalOptions="Center"
                                                                   HasShadow="True" Elevation="3">
                                                    <Label Text="🧾" FontSize="22"
                                                           HorizontalOptions="Center" VerticalOptions="Center" />
                                                </yummy:PancakeView>

                                                <Label Grid.Row="0" Grid.Column="1"
                                                       Text="{Binding paymentItem}"
                                                       FontAttributes="Bold" FontSize="15"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       LineBreakMode="TailTruncation" />

                                                <Label Grid.Row="1" Grid.Column="1"
                                                       Text="{Binding payer_name}"
                                                       FontSize="13"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       LineBreakMode="TailTruncation" />

                                                <yummy:PancakeView Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                                                   BackgroundGradientStartColor="#C8A84B"
                                                                   BackgroundGradientEndColor="#9A7D33"
                                                                   BackgroundGradientAngle="135"
                                                                   CornerRadius="10"
                                                                   HorizontalOptions="End"
                                                                   Padding="11,7"
                                                                   VerticalOptions="Center"
                                                                   HasShadow="True" Elevation="2">
                                                    <Label Text="{Binding amount, StringFormat='₦{0}'}"
                                                           FontAttributes="Bold" FontSize="13"
                                                           TextColor="White" />
                                                </yummy:PancakeView>

                                                <StackLayout Grid.Row="2" Grid.Column="1"
                                                             Orientation="Horizontal" Spacing="6">
                                                    <yummy:PancakeView BackgroundColor="#1A7A45"
                                                                       WidthRequest="6" HeightRequest="6"
                                                                       CornerRadius="3" VerticalOptions="Center" />
                                                    <Label Text="{Binding paymentReference}"
                                                           FontSize="12" FontAttributes="Bold"
                                                           TextColor="#1A7A45"
                                                           TextDecorations="Underline"
                                                           VerticalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_6"/>
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </StackLayout>

                                                <Label Grid.Row="2" Grid.Column="2"
                                                       Text="{Binding dateRecorded, StringFormat='{}{0:MMM d, yyyy}'}"
                                                       FontSize="11" FontAttributes="Bold"
                                                       TextColor="{StaticResource WarningColor}"
                                                       HorizontalTextAlignment="End"
                                                       VerticalOptions="Center" />
                                            </Grid>
                                        </yummy:PancakeView>
                                    </ViewCell>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Footer -->
                        <StackLayout HorizontalOptions="Center" Spacing="8" Margin="0,8,0,0">
                            <yummy:PancakeView BackgroundColor="#0F2A1B"
                                               BorderColor="#1F4030"
                                               BorderThickness="1"
                                               CornerRadius="10"
                                               Padding="16,8">
                                <StackLayout Orientation="Horizontal" Spacing="8" HorizontalOptions="Center">
                                    <Label Text="⚡" FontSize="14" TextColor="#C8A84B" VerticalOptions="Center" />
                                    <Label Text="POWERED BY OSOFTPAY"
                                           TextColor="{StaticResource GoldLight}"
                                           FontSize="11" FontAttributes="Bold"
                                           CharacterSpacing="1"
                                           VerticalOptions="Center" />
                                </StackLayout>
                            </yummy:PancakeView>
                        </StackLayout>
                    </StackLayout>
                </yummy:PancakeView>
            </StackLayout>
        </ScrollView>

        <!-- ══ FLOATING BUTTONS ════════════════════════════════ -->
        <StackLayout x:Name="FloatingButtonsContainer"
                     VerticalOptions="End"
                     HorizontalOptions="End"
                     Margin="22"
                     Spacing="14">

            <yummy:PancakeView x:Name="PrintFloatingButton"
                               BackgroundGradientStartColor="#1A7A45"
                               BackgroundGradientEndColor="#0D4D2A"
                               BackgroundGradientAngle="135"
                               CornerRadius="30"
                               WidthRequest="60" HeightRequest="60"
                               HasShadow="True" Elevation="16"
                               BorderColor="#3DC8A84B" BorderThickness="1.5">
                <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <Image Source="PRINT.png" HeightRequest="20" WidthRequest="20" />
                    <Label Text="PRINT" FontSize="8" TextColor="{StaticResource GoldLight}" FontAttributes="Bold" />
                </StackLayout>
                <yummy:PancakeView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_1"/>
                </yummy:PancakeView.GestureRecognizers>
            </yummy:PancakeView>

            <yummy:PancakeView x:Name="LogoutFloatingButton"
                               BackgroundGradientStartColor="#0D4D2A"
                               BackgroundGradientEndColor="#030F0A"
                               BackgroundGradientAngle="135"
                               CornerRadius="30"
                               WidthRequest="60" HeightRequest="60"
                               HasShadow="True" Elevation="16"
                               BorderColor="#3DC8A84B" BorderThickness="1.5">
                <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="2">
                    <Image Source="shutdown.png" HeightRequest="20" WidthRequest="20" />
                    <Label Text="LOGOUT" FontSize="8" TextColor="{StaticResource GoldLight}" FontAttributes="Bold" />
                </StackLayout>
                <yummy:PancakeView.GestureRecognizers>
                    <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_2"/>
                </yummy:PancakeView.GestureRecognizers>
            </yummy:PancakeView>
        </StackLayout>

        <!-- ══ LOADING OVERLAY ═════════════════════════════════ -->
        <yummy:PancakeView x:Name="LoadingOverlay"
                           BackgroundColor="#99000000"
                           IsVisible="False"
                           HorizontalOptions="FillAndExpand"
                           VerticalOptions="FillAndExpand">
            <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="16">
                <yummy:PancakeView BackgroundColor="{StaticResource CardBackground}"
                                   CornerRadius="20" Padding="32">
                    <StackLayout Spacing="16" HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True"
                                           Color="{StaticResource PrimaryColor}"
                                           WidthRequest="32" HeightRequest="32" />
                        <Label Text="Loading..."
                               TextColor="{StaticResource TextPrimary}"
                               FontSize="16" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                    </StackLayout>
                </yummy:PancakeView>
            </StackLayout>
        </yummy:PancakeView>
    </Grid>
</ContentPage>
