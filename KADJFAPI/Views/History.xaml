<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="KADJFAPI.Views.History"
             xmlns:extensions="http://xamarin.com/schemas/2020/toolkit"
             xmlns:yummy="clr-namespace:Xamarin.Forms.PancakeView;assembly=Xamarin.Forms.PancakeView"
             Padding="0,20,0,0"
             BackgroundColor="#041710"
             NavigationPage.HasNavigationBar="True">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Refresh" Clicked="OnRefreshClicked" />
    </ContentPage.ToolbarItems>

    <Grid BackgroundColor="#F4F7F5"
          RowSpacing="0"
          HorizontalOptions="FillAndExpand"
          VerticalOptions="FillAndExpand"
          Margin="0,-70,0,0">

        <Grid.RowDefinitions>
            <RowDefinition Height="170"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══ Header band ══ -->
        <yummy:PancakeView BackgroundGradientAngle="160"
                           HorizontalOptions="FillAndExpand"
                           VerticalOptions="FillAndExpand">
            <yummy:PancakeView.BackgroundGradientStops>
                <yummy:GradientStopCollection>
                    <yummy:GradientStop Color="#11623A" Offset="0.0"/>
                    <yummy:GradientStop Color="#0A3D22" Offset="0.6"/>
                    <yummy:GradientStop Color="#041710" Offset="1.0"/>
                </yummy:GradientStopCollection>
            </yummy:PancakeView.BackgroundGradientStops>
            <StackLayout Margin="0,-10,0,0" HorizontalOptions="Center" VerticalOptions="Center" Spacing="3">
                <Label Text="KADUNA STATE JUDICIARY"
                       TextColor="#E6CC7A" FontSize="12" FontAttributes="Bold"
                       CharacterSpacing="2" HorizontalTextAlignment="Center"/>
                <Label Text="Transaction Records"
                       TextColor="#9FBFAC" FontSize="10"
                       HorizontalTextAlignment="Center"/>
            </StackLayout>
        </yummy:PancakeView>

        <!-- ══ Date / brand card ══ -->
        <yummy:PancakeView Grid.Row="1"
                           HasShadow="True" Elevation="8"
                           HeightRequest="82"
                           Margin="0,-50,0,0"
                           BackgroundColor="White"
                           CornerRadius="14"
                           BorderColor="#EAF1EC" BorderThickness="1"
                           HorizontalOptions="Center"
                           VerticalOptions="CenterAndExpand">
            <Grid ColumnSpacing="0" HorizontalOptions="FillAndExpand">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="92"/>
                    <ColumnDefinition Width="92"/>
                </Grid.ColumnDefinitions>

                <yummy:PancakeView CornerRadius="14,0,0,14"
                                   BackgroundGradientStartColor="#0D4D2A"
                                   BackgroundGradientEndColor="#1A7A45"
                                   BackgroundGradientAngle="135">
                    <StackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                        <Label x:Name="fixeddate" TextColor="White" FontSize="34"
                               HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Label x:Name="fixmonth" TextColor="#E6CC7A" FontSize="11"
                               HorizontalOptions="Center" Margin="0,-6,0,0" FontAttributes="Bold"/>
                    </StackLayout>
                </yummy:PancakeView>

                <StackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Padding="8">
                    <Label Text="OSOFT" TextColor="#C8A84B" FontSize="22"
                           HorizontalOptions="Center" FontAttributes="Bold"/>
                    <Label Text="KSJ" TextColor="#0D4D2A" FontSize="14"
                           HorizontalOptions="Center" Margin="0,-4,0,0" FontAttributes="Bold"/>
                </StackLayout>
            </Grid>
        </yummy:PancakeView>

        <!-- ══ Statistics card ══ -->
        <yummy:PancakeView Grid.Row="2"
                           HasShadow="True" Elevation="6"
                           BackgroundColor="White"
                           CornerRadius="16"
                           Margin="12,12,12,6"
                           Padding="16"
                           BorderColor="#EAF1EC" BorderThickness="1">
            <StackLayout>
                <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Spacing="8" Margin="0,0,0,14">
                    <yummy:PancakeView BackgroundGradientStartColor="#C8A84B"
                                       BackgroundGradientEndColor="#1A7A45"
                                       BackgroundGradientAngle="135"
                                       WidthRequest="3" HeightRequest="16" CornerRadius="2"/>
                    <Label Text="Transaction Summary" FontSize="15" FontAttributes="Bold" TextColor="#0D4D2A"/>
                </StackLayout>

                <!-- Counts -->
                <Grid ColumnDefinitions="*,*,*,*" Margin="0,0,0,14">
                    <StackLayout Grid.Column="0" HorizontalOptions="Center">
                        <Label Text="{Binding Statistics.TotalTransactions}" FontSize="20" FontAttributes="Bold" TextColor="#0D4D2A" HorizontalTextAlignment="Center"/>
                        <Label Text="Total" FontSize="10" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="1" HorizontalOptions="Center">
                        <Label Text="{Binding Statistics.PaidTransactions}" FontSize="20" FontAttributes="Bold" TextColor="#1A7A45" HorizontalTextAlignment="Center"/>
                        <Label Text="Successful" FontSize="10" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="2" HorizontalOptions="Center">
                        <Label Text="{Binding Statistics.PendingTransactions}" FontSize="20" FontAttributes="Bold" TextColor="#C8A84B" HorizontalTextAlignment="Center"/>
                        <Label Text="Pending" FontSize="10" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Column="3" HorizontalOptions="Center">
                        <Label Text="{Binding Statistics.FailedTransactions}" FontSize="20" FontAttributes="Bold" TextColor="#E05252" HorizontalTextAlignment="Center"/>
                        <Label Text="Failed" FontSize="10" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Grid>

                <BoxView HeightRequest="1" BackgroundColor="#EAF1EC" Margin="0,4,0,14"/>
                <Label Text="Amount Breakdown" FontSize="13" FontAttributes="Bold"
                       TextColor="#0D4D2A" HorizontalOptions="Center" Margin="0,0,0,10"/>

                <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*">
                    <StackLayout Grid.ColumnSpan="2" HorizontalOptions="Center" Margin="0,0,0,10">
                        <Label Text="{Binding Statistics.FormattedTotalAmount}" FontSize="18" FontAttributes="Bold" TextColor="#0D4D2A" HorizontalTextAlignment="Center"/>
                        <Label Text="Total Amount" FontSize="11" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Row="1" Grid.Column="0" HorizontalOptions="Center" Margin="0,4,0,0">
                        <Label Text="{Binding Statistics.FormattedSuccessfulAmount}" FontSize="14" FontAttributes="Bold" TextColor="#1A7A45" HorizontalTextAlignment="Center"/>
                        <Label Text="Successful" FontSize="10" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                    <StackLayout Grid.Row="1" Grid.Column="1" HorizontalOptions="Center" Margin="0,4,0,0">
                        <Label Text="{Binding Statistics.FormattedPendingAmount}" FontSize="14" FontAttributes="Bold" TextColor="#C8A84B" HorizontalTextAlignment="Center"/>
                        <Label Text="Pending" FontSize="10" TextColor="#9CB3A4" HorizontalTextAlignment="Center"/>
                    </StackLayout>
                </Grid>
            </StackLayout>
        </yummy:PancakeView>

        <!-- ══ Search & filter ══ -->
        <yummy:PancakeView Grid.Row="3"
                           HasShadow="True" Elevation="4"
                           BackgroundColor="White"
                           CornerRadius="16"
                           Margin="12,6,12,10"
                           Padding="12"
                           BorderColor="#EAF1EC" BorderThickness="1">
            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="2*,*">

                <yummy:PancakeView BorderThickness="1.5" BorderColor="#DDE7E0"
                                   CornerRadius="11" BackgroundColor="#F6FAF7">
                    <SearchBar x:Name="searchentry"
                               Text="{Binding SearchText}"
                               TextChanged="OnSearchTextChanged"
                               Placeholder="Search by name, reference…"
                               PlaceholderColor="#9CB3A4"
                               TextColor="#0D4D2A"
                               FontSize="14"
                               BackgroundColor="Transparent"/>
                </yummy:PancakeView>

                <yummy:PancakeView Grid.Column="1"
                                   BorderThickness="1.5" BorderColor="#DDE7E0"
                                   CornerRadius="11" BackgroundColor="#F6FAF7"
                                   Margin="10,0,0,0" Padding="10,0">
                    <Picker x:Name="filterPicker"
                            SelectedItem="{Binding SelectedFilter}"
                            SelectedIndexChanged="OnFilterChanged"
                            TextColor="#0D4D2A" FontSize="14">
                        <Picker.Items>
                            <x:String>All</x:String>
                            <x:String>Paid</x:String>
                            <x:String>Pending</x:String>
                            <x:String>Failed</x:String>
                        </Picker.Items>
                    </Picker>
                </yummy:PancakeView>

                <StackLayout Grid.Row="1" Grid.ColumnSpan="2"
                             Orientation="Horizontal" HorizontalOptions="Center" Margin="0,10,0,0">
                    <Label Text="Filtered Total:" FontSize="13" FontAttributes="Bold" TextColor="#0D4D2A"/>
                    <Label Text="{Binding Statistics.FormattedTotalAmount}"
                           FontSize="13" FontAttributes="Bold" TextColor="#E05252" Margin="5,0,0,0"/>
                </StackLayout>
            </Grid>
        </yummy:PancakeView>

        <!-- ══ Content ══ -->
        <Grid Grid.Row="4" Margin="12,0,12,10">

            <!-- Loading -->
            <StackLayout IsVisible="{Binding IsLoading}" HorizontalOptions="Center" VerticalOptions="Center">
                <ActivityIndicator IsRunning="{Binding IsLoading}" Color="#0D4D2A" WidthRequest="48" HeightRequest="48"/>
                <Label Text="Loading transactions…" TextColor="#0D4D2A" FontSize="15" HorizontalOptions="Center" Margin="0,10,0,0"/>
            </StackLayout>

            <!-- Empty -->
            <StackLayout IsVisible="{Binding HasNoData}" HorizontalOptions="Center" VerticalOptions="Center">
                <yummy:PancakeView BackgroundColor="#EAF3EE" CornerRadius="44"
                                   WidthRequest="88" HeightRequest="88" HorizontalOptions="Center">
                    <Label Text="📋" FontSize="40" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
                </yummy:PancakeView>
                <Label Text="No transactions found" FontSize="17" FontAttributes="Bold" TextColor="#0D4D2A" HorizontalOptions="Center" Margin="0,14,0,0"/>
                <Label Text="Try adjusting your search or filter, or tap Retry to reload."
                       FontSize="13.5" TextColor="#5E7A68" HorizontalOptions="Center"
                       HorizontalTextAlignment="Center" Margin="20,8,20,18"/>
                <Button Text="Retry" Clicked="OnRetryClicked"
                        BackgroundColor="#0D4D2A" TextColor="White"
                        CornerRadius="11" WidthRequest="150" HeightRequest="46"/>
            </StackLayout>

            <!-- List -->
            <CollectionView x:Name="historyCollectionView"
                            ItemsSource="{Binding HistoryItems}"
                            IsVisible="{Binding HasData}"
                            BackgroundColor="Transparent"
                            SelectionMode="None">

                <CollectionView.Header>
                    <Label Text="TRANSACTION HISTORY"
                           TextColor="#0D4D2A" FontSize="16" FontAttributes="Bold"
                           CharacterSpacing="1" Margin="4,8,4,12"/>
                </CollectionView.Header>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,5">
                            <yummy:PancakeView HasShadow="True" Elevation="3"
                                               BackgroundColor="White"
                                               CornerRadius="14" Padding="0"
                                               BorderColor="#EAF1EC" BorderThickness="1"
                                               Margin="0,4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="5"/>
                                        <ColumnDefinition Width="58"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <BoxView BackgroundColor="{Binding StatusColor}"
                                             VerticalOptions="FillAndExpand"
                                             HorizontalOptions="FillAndExpand"/>

                                    <StackLayout Grid.Column="1" HorizontalOptions="Center" VerticalOptions="Center" Padding="8">
                                        <yummy:PancakeView CornerRadius="12"
                                                           WidthRequest="42" HeightRequest="42"
                                                           BackgroundGradientStartColor="#1A7A45"
                                                           BackgroundGradientEndColor="#0D4D2A"
                                                           BackgroundGradientAngle="135"
                                                           Padding="0" HorizontalOptions="Center">
                                            <Image Source="Logo" HorizontalOptions="Center"
                                                   VerticalOptions="Center" Aspect="AspectFit"
                                                   HeightRequest="26" WidthRequest="26" Margin="7"/>
                                        </yummy:PancakeView>
                                        <Label Text="KSJ" TextColor="#0D4D2A" FontSize="9"
                                               FontAttributes="Bold" HorizontalOptions="Center" Margin="0,3,0,0"/>
                                    </StackLayout>

                                    <extensions:Expander Grid.Column="2" Padding="15" IsExpanded="False">
                                        <extensions:Expander.Header>
                                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                                                <Grid Grid.Row="0" ColumnDefinitions="Auto,*">
                                                    <Label Text="Name:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                    <Label Grid.Column="1" Text="{Binding DisplayName}" TextColor="#14241B" FontSize="12" FontAttributes="Bold" Margin="10,0,0,0"/>
                                                </Grid>
                                                <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                    <Label Text="Item:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                    <Label Grid.Column="1" Text="{Binding ServiceNameTruncated}" TextColor="#14241B" FontSize="12" Margin="10,0,0,0"/>
                                                </Grid>
                                                <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                    <Label Text="Status:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                    <Label Grid.Column="1" Text="{Binding status}" TextColor="{Binding StatusColor}" FontSize="12" FontAttributes="Bold" Margin="10,0,0,0"/>
                                                </Grid>
                                                <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                    <Label Text="Amount:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                    <Label Grid.Column="1" Text="{Binding FormattedAmount}" TextColor="#E05252" FontSize="14" FontAttributes="Bold" Margin="10,0,0,0"/>
                                                </Grid>
                                                <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                    <Label Text="Date:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                    <Label Grid.Column="1" Text="{Binding FormattedDate}" TextColor="#1A7A45" FontSize="12" Margin="10,0,0,0"/>
                                                </Grid>
                                            </Grid>
                                        </extensions:Expander.Header>

                                        <extensions:Expander.Content>
                                            <yummy:PancakeView BackgroundColor="#F6FAF7" CornerRadius="10"
                                                               Padding="15" Margin="0,10,0,0"
                                                               BorderColor="#EAF1EC" BorderThickness="1">
                                                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
                                                    <Label Grid.Row="0" Text="Additional Details" FontSize="14" FontAttributes="Bold" TextColor="#0D4D2A" Margin="0,0,0,10"/>

                                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="Email:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding DisplayEmail}" TextColor="#14241B" FontSize="12" Margin="10,0,0,0"/>
                                                    </Grid>
                                                    <Grid Grid.Row="2" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="Phone:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding phoneNumber}" TextColor="#14241B" FontSize="12" Margin="10,0,0,0"/>
                                                    </Grid>
                                                    <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="Reference:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding paymentReference}" TextColor="#1A7A45" FontSize="12" FontAttributes="Bold" TextDecorations="Underline" Margin="10,0,0,0">
                                                            <Label.GestureRecognizers>
                                                                <TapGestureRecognizer Tapped="TapGestureRecognizer_Tapped_1"/>
                                                            </Label.GestureRecognizers>
                                                        </Label>
                                                    </Grid>
                                                    <Grid Grid.Row="4" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="Tax ID:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding taxId, FallbackValue='—', TargetNullValue='—'}" TextColor="#E05252" FontSize="12" FontAttributes="Bold" Margin="10,0,0,0"/>
                                                    </Grid>
                                                    <Grid Grid.Row="5" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="MDA:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding mda, FallbackValue='—', TargetNullValue='—'}" TextColor="#14241B" FontSize="12" Margin="10,0,0,0"/>
                                                    </Grid>
                                                    <Grid Grid.Row="6" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="Court:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding court, FallbackValue='—', TargetNullValue='—'}" TextColor="#14241B" FontSize="12" Margin="10,0,0,0"/>
                                                    </Grid>
                                                    <Grid Grid.Row="7" ColumnDefinitions="Auto,*" Margin="0,5,0,0">
                                                        <Label Text="Payment Date:" FontSize="12" FontAttributes="Bold" TextColor="#0D4D2A"/>
                                                        <Label Grid.Column="1" Text="{Binding date_of_payment, FallbackValue='—', TargetNullValue='—'}" TextColor="#7A4FA0" FontSize="12" FontAttributes="Bold" Margin="10,0,0,0"/>
                                                    </Grid>
                                                </Grid>
                                            </yummy:PancakeView>
                                        </extensions:Expander.Content>
                                    </extensions:Expander>
                                </Grid>
                            </yummy:PancakeView>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

                <CollectionView.Footer>
                    <StackLayout Padding="10" IsVisible="{Binding HasData}">
                        <BoxView HeightRequest="1" BackgroundColor="#EAF1EC" Margin="0,10"/>
                        <Label Text="{Binding Statistics.TotalTransactions, StringFormat='Total: {0} transactions'}"
                               TextColor="#0D4D2A" FontSize="14" FontAttributes="Bold" HorizontalOptions="Center"/>
                        <StackLayout Orientation="Horizontal" HorizontalOptions="Center" Margin="0,5,0,0">
                            <Label Text="Successful: " TextColor="#1A7A45" FontSize="12" FontAttributes="Bold"/>
                            <Label Text="{Binding Statistics.FormattedSuccessfulAmount}" TextColor="#1A7A45" FontSize="12" FontAttributes="Bold"/>
                            <Label Text=" | Pending: " TextColor="#C8A84B" FontSize="12" FontAttributes="Bold" Margin="10,0,0,0"/>
                            <Label Text="{Binding Statistics.FormattedPendingAmount}" TextColor="#C8A84B" FontSize="12" FontAttributes="Bold"/>
                        </StackLayout>
                        <Label Text="{Binding Statistics.FormattedTotalAmount, StringFormat='Grand Total: {0}'}"
                               TextColor="#E05252" FontSize="16" FontAttributes="Bold"
                               HorizontalOptions="Center" Margin="0,5,0,20"/>
                    </StackLayout>
                </CollectionView.Footer>
            </CollectionView>
        </Grid>
    </Grid>
</ContentPage>
